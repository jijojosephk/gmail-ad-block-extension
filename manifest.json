{
    "name": "Gmail Ad-blocker",
    "description": "Hides sponsored rows from the gmail grid",
    "version": "0.1",
    "manifest_version": 3,
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "index.html"
    },
    "permissions": [
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "https://mail.google.com/*"
    ],
    "content_scripts": [
        {
            "js": [
                "scripts/index.js"
            ],
            "matches": [
                "https://mail.google.com/*"
            ]
        }
    ]
}